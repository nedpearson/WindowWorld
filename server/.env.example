# ═══════════════════════════════════════════════════════════════════
# WindowWorld Louisiana — Sales Operating System
# server/.env.example — copy to .env and fill in values
# NEVER commit .env to git — this file is safe to commit
# ═══════════════════════════════════════════════════════════════════

# ─── REQUIRED ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/windowworld
JWT_SECRET=                    # min 32 chars — generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# ─── APP CONFIG ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://windowworld.bridgebox.ai
APP_URL=https://windowworld.bridgebox.ai
API_URL=https://windowworld.bridgebox.ai/api/v1

# ─── AI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=                # required for all AI features (pitch, scoring, vision, property scan)
AI_TEXT_MODEL=gpt-4o
AI_VISION_MODEL=gpt-4o

# ─── STORAGE (choose one provider) ─────────────────────────────────
STORAGE_PROVIDER=s3            # 's3' | 'local' (local = /uploads on disk)
S3_BUCKET_NAME=                # e.g. windowworld-documents
S3_REGION=us-east-1
S3_ENDPOINT=                   # leave blank for AWS S3; set for Cloudflare R2 (e.g. https://<account>.r2.cloudflarestorage.com)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL_PREFIX=          # optional CDN prefix — if set, used instead of presigned URLs

# ─── EMAIL ─────────────────────────────────────────────────────────
RESEND_API_KEY=                # required for email notifications
EMAIL_FROM=WindowWorld Louisiana <noreply@windowworldla.com>

# ─── SMS / PHONE ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=            # required for SMS + click-to-call
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=            # e.g. +15045551234

# ─── BACKGROUND JOBS ───────────────────────────────────────────────
REDIS_URL=                     # optional — falls back to synchronous in-process queue if not set
                               # format: redis://:password@host:6379

# ─── ERROR TRACKING ────────────────────────────────────────────────
SENTRY_DSN=                    # optional — Sentry project DSN

# ─── GOOGLE OAUTH ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=              # required for Google Sign-In
GOOGLE_CLIENT_SECRET=          # required for Google Sign-In + Calendar sync
GOOGLE_REDIRECT_URI=https://windowworld.bridgebox.ai/api/v1/calendar/oauth/callback

# ─── PUSH NOTIFICATIONS (PWA) ──────────────────────────────────────
VAPID_PUBLIC_KEY=              # generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@windowworldla.com

# ─── RAILWAY AUTO-INJECTED (do not set manually) ───────────────────
# RAILWAY_PUBLIC_DOMAIN — auto-set by Railway, used by CORS allowlist
# PORT               — auto-set by Railway (overrides the value above)
