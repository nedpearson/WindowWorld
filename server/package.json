{
    "name": "@windowworld/server",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "prisma generate && tsc",
        "start": "prisma db push --accept-data-loss && npx prisma db seed && node dist/index.js",
        "migrate": "prisma migrate dev",
        "migrate:deploy": "prisma migrate deploy",
        "generate": "prisma generate",
        "seed": "tsx prisma/seed.ts",
        "db:reset": "prisma migrate reset --force",
        "studio": "prisma studio",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1038.0",
        "@aws-sdk/s3-request-presigner": "^3.1038.0",
        "@prisma/client": "^5.22.0",
        "@sentry/node": "^10.50.0",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.76.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "express-async-errors": "^3.1.1",
        "express-rate-limit": "^7.4.1",
        "express-validator": "^7.2.0",
        "google-auth-library": "^10.6.2",
        "googleapis": "^171.4.0",
        "helmet": "^8.0.0",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.7",
        "openai": "^4.68.4",
        "prisma": "^5.22.0",
        "puppeteer": "^23.0.0",
        "resend": "^6.12.2",
        "sharp": "^0.34.5",
        "socket.io": "^4.8.3",
        "tsx": "^4.19.2",
        "twilio": "^5.13.1",
        "uuid": "^14.0.0",
        "web-push": "^3.6.7",
        "winston": "^3.15.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.4.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^2.0.0",
        "@types/node": "^22.9.0",
        "@types/nodemailer": "^8.0.0",
        "@types/supertest": "^7.2.0",
        "@types/web-push": "^3.6.4",
        "supertest": "^7.2.2",
        "typescript": "^5.6.3",
        "vitest": "^4.1.4"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "overrides": {
        "uuid": "^14.0.0"
    }
}
