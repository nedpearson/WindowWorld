// WindowWorld — Complete Database Schema
// Production-grade relational schema for AI-first window sales platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  SALES_MANAGER
  SALES_REP
  FIELD_MEASURE_TECH
  OFFICE_ADMIN
  FINANCE_BILLING
  READ_ONLY_ANALYST
}

enum LeadStatus {
  NEW_LEAD
  ATTEMPTING_CONTACT
  CONTACTED
  QUALIFIED
  APPOINTMENT_SET
  INSPECTION_COMPLETE
  MEASURING_COMPLETE
  PROPOSAL_SENT
  FOLLOW_UP
  VERBAL_COMMIT
  SOLD
  AWAITING_VERIFICATION
  ORDER_READY
  ORDERED
  INSTALLED
  PAID
  LOST
  NURTURE
}

enum MeasurementStatus {
  ESTIMATED
  REVIEWED
  VERIFIED_ONSITE
  APPROVED_FOR_ORDER
}

enum ProposalStatus {
  DRAFT
  PENDING_REVIEW
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  REVISED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
  REFUNDED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
  RESCHEDULED
}

enum ContactMethod {
  PHONE
  EMAIL
  SMS
  IN_PERSON
  DOOR_KNOCK
}

enum ActivityType {
  CALL
  EMAIL
  SMS
  MEETING
  NOTE
  TASK_COMPLETE
  STATUS_CHANGE
  APPOINTMENT_SET
  PROPOSAL_SENT
  INVOICE_SENT
  PAYMENT_RECEIVED
  DOOR_KNOCK
  VOICEMAIL
  SYSTEM_AUTO
}

enum WindowType {
  SINGLE_HUNG
  DOUBLE_HUNG
  SLIDER
  CASEMENT
  AWNING
  PICTURE
  BAY
  BOW
  SPECIALTY_SHAPE
  TRANSOM
  GARDEN
  FIXED
  PATIO_DOOR
  SLIDING_GLASS_DOOR
  UNKNOWN
}

enum FrameMaterial {
  VINYL
  WOOD
  ALUMINUM
  FIBERGLASS
  COMPOSITE
  UNKNOWN
}

enum ConditionRating {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
  UNKNOWN
}

enum DocumentType {
  PHOTO_EXTERIOR
  PHOTO_INTERIOR
  PHOTO_DAMAGE
  PHOTO_HARDWARE
  PHOTO_MEASUREMENT
  PHOTO_BEFORE
  PHOTO_AFTER
  PROPOSAL_PDF
  INVOICE_PDF
  CONTRACT
  PERMIT
  WARRANTY
  RECEIPT
  OTHER
}

enum ExpenseCategory {
  MATERIALS
  PERMITS
  DISPOSAL
  LABOR
  TRAVEL
  EQUIPMENT
  OTHER
}

enum AutomationTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  APPOINTMENT_SET
  APPOINTMENT_COMPLETED
  PROPOSAL_SENT
  QUOTE_EXPIRED
  INVOICE_OVERDUE
  NO_CONTACT_DAYS
  INSTALL_COMPLETE
  PAYMENT_RECEIVED
  STORM_EVENT
  MANUAL
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
  FAILED
}

enum PitchMode {
  CONSULTATIVE
  URGENCY_BASED
  PREMIUM_VALUE
  BUDGET_CONSCIOUS
  ENERGY_SAVINGS
  INSURANCE_STORM
  COMFORT_FAMILY
  FINANCING_FIRST
}

// ============================================================
// ORGANIZATIONS
// ============================================================

model Organization {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  logoUrl    String?
  brandColor String?
  address    String?
  city       String?  @default("Baton Rouge")
  state      String?  @default("Louisiana")
  zip        String?
  phone      String?
  email      String?
  website    String?
  settings   Json? // Flexible org-level settings
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users             User[]
  territories       Territory[]
  leads             Lead[]
  properties        Property[]
  products          Product[]
  productCategories ProductCategory[]
  templates         Template[]
  campaigns         Campaign[]
  communicationLogs CommunicationLog[]

  @@map("organizations")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id               String    @id @default(uuid())
  organizationId   String
  email            String    @unique
  googleId         String?   @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  avatarUrl        String?
  role             UserRole  @default(SALES_REP)
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  // Notification preferences stored as JSON
  notifPreferences Json?     @default("{}")

  // Google Calendar OAuth
  gcalAccessToken  String? // Encrypted; expires quickly
  gcalRefreshToken String? // Encrypted; long-lived, used to auto-refresh
  gcalTokenExpiry  DateTime? // When the access token expires
  gcalCalendarId   String? // Calendar ID to check (defaults to 'primary')
  gcalSyncEnabled  Boolean   @default(false) // User has opted in
  gcalConnectedAt  DateTime? // When they last connected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id])
  territories       TerritoryUser[]
  assignedLeads     Lead[]             @relation("assignedRep")
  activities        Activity[]
  appointments      Appointment[]      @relation("createdBy")
  proposals         Proposal[]         @relation("createdBy")
  invoices          Invoice[]          @relation("createdBy")
  measurements      Measurement[]      @relation("measuredBy")
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  expensesCreated   JobExpense[]       @relation("ExpensesCreated")
  expensesVerified  JobExpense[]       @relation("ExpensesVerified")
  communicationLogs CommunicationLog[]
  documentsUploaded Document[]         @relation("uploadedBy")

  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ============================================================
// TERRITORIES
// ============================================================

model Territory {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  state          String   @default("Louisiana")
  parishes       String[] // Array of parish names
  zipCodes       String[] // Zip codes in territory
  centerLat      Float?
  centerLng      Float?
  radiusMiles    Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  users        TerritoryUser[]
  leads        Lead[]

  @@map("territories")
}

model TerritoryUser {
  id          String   @id @default(uuid())
  territoryId String
  userId      String
  isPrimary   Boolean  @default(false)
  assignedAt  DateTime @default(now())

  territory Territory @relation(fields: [territoryId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([territoryId, userId])
  @@map("territory_users")
}

// ============================================================
// LEADS
// ============================================================

model Lead {
  id             String     @id @default(uuid())
  organizationId String
  territoryId    String?
  assignedRepId  String?
  status         LeadStatus @default(NEW_LEAD)
  source         String? // web, referral, door-knock, storm-list, etc.
  sourceDetail   String?
  campaignId     String?

  // Core lead data
  firstName String?
  lastName  String?
  email     String?
  phone     String?
  phone2    String?
  address   String?
  city      String?
  state     String? @default("Louisiana")
  zip       String?
  parish    String?
  lat       Float?
  lng       Float?

  // Scoring
  leadScore           Int?   @default(0) // 0-100
  urgencyScore        Int?   @default(0)
  closeProbability    Float? // 0.0 - 1.0
  financingPropensity Float?
  estimatedRevenue    Float?

  // Context flags
  isStormLead   Boolean @default(false)
  stormEventId  String?
  isDuplicate   Boolean @default(false)
  duplicateOfId String?

  // Follow-up
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  followUpCount   Int       @default(0)

  // Loss tracking
  lostReason       String?
  lostToCompetitor String?

  // Referral
  referredById String? // Lead ID that referred this lead

  notes        String?
  tags         String[]
  customFields Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  territory    Territory?   @relation(fields: [territoryId], references: [id])
  assignedRep  User?        @relation("assignedRep", fields: [assignedRepId], references: [id])
  campaign     Campaign?    @relation(fields: [campaignId], references: [id])

  leadScores        LeadScore[]
  contacts          Contact[]
  properties        Property[]         @relation("leadProperties")
  appointments      Appointment[]
  activities        Activity[]
  notes_rel         Note[]
  tasks             Task[]
  proposals         Proposal[]
  quotes            Quote[]
  documents         Document[]
  aiAnalyses        AiAnalysis[]
  Inspection        Inspection[]
  expenses          JobExpense[]
  communicationLogs CommunicationLog[]

  @@index([organizationId, status])
  @@index([organizationId, assignedRepId])
  @@index([organizationId, isStormLead])
  @@index([organizationId, leadScore])
  @@index([assignedRepId])
  @@index([zip])
  @@index([parish])
  @@index([leadScore])
  @@map("leads")
}

model LeadScore {
  id     String @id @default(uuid())
  leadId String

  // Individual signal scores
  homeAgeScore         Float?
  weatherExposureScore Float?
  neighborhoodScore    Float?
  priorContactScore    Float?
  responseScore        Float?
  financingScore       Float?
  referralScore        Float?
  campaignScore        Float?

  // Composite scores
  totalScore       Float @default(0)
  urgencyScore     Float @default(0)
  closeProbability Float @default(0)

  // AI outputs
  recommendedPitchAngle    PitchMode?
  recommendedProduct       String?
  estimatedProjectSize     String?
  estimatedRevenueBand     String?
  likelyObjections         String[]
  suggestedContactSequence Json?

  // Meta
  scoredAt        DateTime @default(now())
  scoredBy        String   @default("system") // "system" or userId
  confidenceScore Float    @default(0)
  rationale       String?

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("lead_scores")
}

// ============================================================
// CONTACTS / HOMEOWNERS
// ============================================================

model Contact {
  id         String  @id @default(uuid())
  leadId     String?
  propertyId String?

  firstName String
  lastName  String
  email     String?
  phone     String?
  phone2    String?
  isOwner   Boolean @default(true)
  isSpouse  Boolean @default(false)
  isPrimary Boolean @default(true)

  preferredContactMethod ContactMethod?
  bestTimeToContact      String?
  doNotCall              Boolean        @default(false)
  doNotEmail             Boolean        @default(false)
  doNotText              Boolean        @default(false)

  notes String?
  tags  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead     Lead?     @relation(fields: [leadId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])

  @@index([leadId])
  @@index([propertyId])
  @@map("contacts")
}

// ============================================================
// PROPERTIES
// ============================================================

model Property {
  id             String  @id @default(uuid())
  organizationId String?

  address String
  unit    String?
  city    String
  state   String  @default("Louisiana")
  zip     String
  parish  String?
  lat     Float?
  lng     Float?

  // Property details
  yearBuilt      Int?
  squareFootage  Float?
  stories        Int?
  propertyType   String? // single-family, multi-family, condo
  ownershipType  String? // owner-occupied, rental, commercial
  estimatedValue Float?

  // Window context
  estimatedWindowCount  Int?
  lastWindowReplacement Int? // year
  windowCondition       ConditionRating?

  // Weather/risk
  floodZone     String?
  stormExposure String? // low, medium, high

  notes String?
  tags  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads        Lead[]        @relation("leadProperties")
  contacts     Contact[]
  inspections  Inspection[]
  openings     Opening[]
  documents    Document[]
  Organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([zip])
  @@index([parish])
  @@index([organizationId])
  @@map("properties")
}

// ============================================================
// APPOINTMENTS
// ============================================================

model Appointment {
  id          String @id @default(uuid())
  leadId      String
  createdById String

  title       String
  type        String // initial-consult, measurement, follow-up, install-check
  status      AppointmentStatus @default(SCHEDULED)
  scheduledAt DateTime
  endAt       DateTime?
  duration    Int? // minutes

  address String?
  lat     Float?
  lng     Float?

  notes   String?
  outcome String?

  reminderSent     Boolean @default(false)
  confirmationSent Boolean @default(false)

  // Google Calendar sync
  googleEventId String? // GCal event ID — set after syncing to rep's Google Calendar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead        Lead         @relation(fields: [leadId], references: [id])
  createdBy   User         @relation("createdBy", fields: [createdById], references: [id])
  inspections Inspection[]

  @@index([scheduledAt])
  @@index([leadId])
  @@index([createdById])
  @@map("appointments")
}

// ============================================================
// INSPECTIONS
// ============================================================

model Inspection {
  id            String  @id @default(uuid())
  leadId        String
  appointmentId String?
  propertyId    String?
  inspectedById String?

  status String @default("draft") // draft, in-progress, complete, verified

  // Summary
  totalOpenings    Int?
  visitSummary     String?
  complexityRating String? // simple, moderate, complex, specialty

  // AI summary
  aiSummary    String?
  aiConfidence Float?

  notes         String?
  internalNotes String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead        Lead         @relation(fields: [leadId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  property    Property?    @relation(fields: [propertyId], references: [id])
  openings    Opening[]
  documents   Document[]
  aiAnalyses  AiAnalysis[]

  @@index([leadId])
  @@map("inspections")
}

// ============================================================
// OPENINGS / WINDOWS
// ============================================================

model Opening {
  id           String  @id @default(uuid())
  inspectionId String?
  propertyId   String?

  openingId  String? // Human-readable: "bedroom-1-north", "living-east"
  roomLabel  String?
  floorLevel Int?    @default(1) // 1 = ground floor

  // Window classification
  windowType    WindowType    @default(UNKNOWN)
  frameMaterial FrameMaterial @default(UNKNOWN)

  // Condition
  condition        ConditionRating @default(UNKNOWN)
  hasCondensation  Boolean         @default(false)
  hasSealFailure   Boolean         @default(false)
  hasDamagedTrim   Boolean         @default(false)
  hasObstructions  Boolean         @default(false)
  obstructionNotes String?

  // Installation
  accessComplexity String? // easy, moderate, difficult, specialty
  requiresLadder   Boolean @default(false)
  ladderHeight     Int? // feet

  // Measurement ref
  measurement Measurement?

  // AI analysis
  aiWindowType WindowType?
  aiConfidence Float?
  aiNotes      String?
  aiAnalysisId String?

  // Product recommendation
  recommendedProductId String?
  recommendedProduct   Product? @relation("recommendedForOpening", fields: [recommendedProductId], references: [id])

  gridPattern    String?
  colorFinish    String?
  glassOptions   String[]
  egressRequired Boolean  @default(false)

  isVerified Boolean @default(false)
  notes      String?

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inspection     Inspection?     @relation(fields: [inspectionId], references: [id])
  property       Property?       @relation(fields: [propertyId], references: [id])
  documents      Document[]
  aiAnalyses     AiAnalysis[]
  quoteLineItems QuoteLineItem[]

  @@index([inspectionId])
  @@index([propertyId])
  @@map("openings")
}

// ============================================================
// MEASUREMENTS
// ============================================================

model Measurement {
  id           String  @id @default(uuid())
  openingId    String  @unique
  measuredById String?

  // Measurement values
  widthHigh   Float? // inches - top measurement
  widthMid    Float? // inches - middle measurement
  widthLow    Float? // inches - bottom measurement
  heightLeft  Float? // inches - left measurement
  heightMid   Float? // inches - center measurement
  heightRight Float? // inches - right measurement
  depth       Float? // inches - sill depth

  // Used dimensions (smallest = rough opening standard)
  finalWidth  Float?
  finalHeight Float?

  // Sill & jamb
  sillCondition    String?
  sillSlope        Boolean  @default(false)
  jambDepth        Float?
  isSquare         Boolean? // null = unknown
  outOfSquareNotes String?

  // Trim notes
  interiorTrimNotes String?
  exteriorTrimNotes String?

  // Status
  status             MeasurementStatus @default(ESTIMATED)
  verifiedById       String?
  verifiedAt         DateTime?
  approvedForOrderAt DateTime?
  approvedById       String?

  // Capture method
  captureMethod   String? // manual, guided, ar, reference-object, lidar
  confidenceScore Float? // 0.0 - 1.0

  // AI estimates (clearly labeled)
  aiEstimatedWidth     Float?
  aiEstimatedHeight    Float?
  aiEstimateConfidence Float?
  aiEstimateNotes      String?
  isAiEstimated        Boolean @default(false)

  notes      String?
  measuredAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  opening    Opening              @relation(fields: [openingId], references: [id])
  measuredBy User?                @relation("measuredBy", fields: [measuredById], references: [id])
  history    MeasurementHistory[]

  @@index([status])
  @@map("measurements")
}

model MeasurementHistory {
  id            String  @id @default(uuid())
  measurementId String
  changedById   String?

  fieldName String
  oldValue  String?
  newValue  String?
  reason    String?

  changedAt DateTime @default(now())

  measurement Measurement @relation(fields: [measurementId], references: [id])

  @@map("measurement_history")
}

// ============================================================
// PRODUCTS / CATALOG
// ============================================================

model Product {
  id             String  @id @default(uuid())
  organizationId String?

  manufacturer String?
  productLine  String?
  name         String
  sku          String? @unique

  windowType    WindowType?
  frameMaterial FrameMaterial?

  description String?
  features    String[]

  // Pricing
  basePrice       Float?
  laborRate       Float?
  installIncluded Boolean @default(true)

  // Options (configured separately via ProductOption)
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  // Energy/cert
  energyStarCertified Boolean @default(false)
  uFactor             Float?
  solarHeatGain       Float?

  // Warranty
  warrantyYears Int?
  warrantyNotes String?

  notes     String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization?   @relation(fields: [organizationId], references: [id])
  options        ProductOption[]
  quoteLineItems QuoteLineItem[]
  recommendedFor Opening[]       @relation("recommendedForOpening")

  // NEW CATALOG TAXONOMY RELATIONS
  categoryId    String?
  subcategoryId String?
  seriesId      String?
  styleId       String?

  category    ProductCategory?    @relation(fields: [categoryId], references: [id])
  subcategory ProductSubcategory? @relation(fields: [subcategoryId], references: [id])
  series      ProductSeries?      @relation(fields: [seriesId], references: [id])
  style       ProductStyle?       @relation(fields: [styleId], references: [id])

  visuals                  ProductVisual[]
  extendedFeatures         ProductFeature[]
  benefits                 ProductBenefit[]
  measurementRequirements  ProductMeasurementRequirement[]
  installationRequirements ProductInstallationRequirement[]
  pricingRules             ProductPricingRule[]
  recommendationRules      ProductRecommendationRule[]

  // Extended product info
  salesNotes     String?
  homeownerNotes String?
  technicalNotes String?
  financingNotes String?
  installNotes   String?
  sourceUrl      String?
  internalNotes  String?

  @@map("products")
}

model ProductOption {
  id        String @id @default(uuid())
  productId String

  category   String // color, glass, grid, hardware, addon
  name       String
  value      String?
  priceDelta Float   @default(0)
  isDefault  Boolean @default(false)
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@map("product_options")
}

// ============================================================
// NEW CATALOG TAXONOMY
// ============================================================

model ProductCategory {
  id             String  @id @default(uuid())
  organizationId String?
  name           String
  slug           String  @unique
  description    String?
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)

  subcategories ProductSubcategory[]
  products      Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("product_categories")
}

model ProductSubcategory {
  id          String  @id @default(uuid())
  categoryId  String
  name        String
  slug        String  @unique
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  category ProductCategory @relation(fields: [categoryId], references: [id])
  series   ProductSeries[]
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_subcategories")
}

model ProductSeries {
  id            String  @id @default(uuid())
  subcategoryId String?
  name          String
  slug          String  @unique
  description   String?
  sortOrder     Int     @default(0)
  isActive      Boolean @default(true)

  subcategory ProductSubcategory? @relation(fields: [subcategoryId], references: [id])
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_series")
}

model ProductStyle {
  id          String  @id @default(uuid())
  name        String
  description String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_styles")
}

model ProductVisual {
  id        String @id @default(uuid())
  productId String

  url       String
  altText   String?
  sourceUrl String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_visuals")
}

model ProductFeature {
  id        String @id @default(uuid())
  productId String

  title       String
  description String?
  icon        String?
  sortOrder   Int     @default(0)

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_features")
}

model ProductBenefit {
  id        String @id @default(uuid())
  productId String

  title       String
  description String?
  audience    String?
  sortOrder   Int     @default(0)

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_benefits")
}

model ProductMeasurementRequirement {
  id        String @id @default(uuid())
  productId String

  name       String
  dataType   String
  isRequired Boolean @default(true)
  options    Json?

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_measurement_reqs")
}

model ProductInstallationRequirement {
  id        String @id @default(uuid())
  productId String

  title       String
  description String?
  isChecklist Boolean @default(true)

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_installation_reqs")
}

model ProductPricingRule {
  id        String @id @default(uuid())
  productId String

  ruleType  String
  value     Float
  condition Json?

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_pricing_rules")
}

model ProductRecommendationRule {
  id        String @id @default(uuid())
  productId String

  triggerType String
  confidence  Float   @default(1.0)
  pitchAngle  String?

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_recommendation_rules")
}

// ============================================================
// QUOTES
// ============================================================

model Quote {
  id          String  @id @default(uuid())
  leadId      String
  createdById String?

  status     String    @default("draft") // draft, pending-review, approved, sent, accepted, declined, expired
  validUntil DateTime?

  // Totals
  subtotal        Float @default(0)
  laborTotal      Float @default(0)
  discountAmount  Float @default(0)
  discountPercent Float @default(0)
  taxRate         Float @default(0)
  taxAmount       Float @default(0)
  total           Float @default(0)

  // Financing
  financingApplied Boolean @default(false)
  financingPlan    String?
  financingMonths  Int?
  monthlyPayment   Float?

  // Margin tracking
  totalCost     Float?
  marginAmount  Float?
  marginPercent Float?

  // Approval
  requiresApproval Boolean   @default(false)
  approvedById     String?
  approvedAt       DateTime?

  // Discounts
  promoCode    String?
  managerNotes String?

  notes         String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead      Lead            @relation(fields: [leadId], references: [id])
  lineItems QuoteLineItem[]
  proposals Proposal[]
  @@index([leadId])
  @@map("quotes")
}

model QuoteLineItem {
  id        String  @id @default(uuid())
  quoteId   String
  openingId String?
  productId String?

  description String
  quantity    Int    @default(1)
  unitPrice   Float  @default(0)
  unitCost    Float?
  discount    Float  @default(0)
  total       Float  @default(0)

  // Window-specific
  widthIn  Float?
  heightIn Float?
  options  Json? // Selected product options

  isAlternate  Boolean @default(false) // Is this an alternate option?
  alternateFor String? // QuoteLineItem ID this is alternate for

  sortOrder Int     @default(0)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id])
  opening Opening? @relation(fields: [openingId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@map("quote_line_items")
}

// ============================================================
// PROPOSALS
// ============================================================

model Proposal {
  id          String  @id @default(uuid())
  leadId      String
  quoteId     String?
  createdById String

  status ProposalStatus @default(DRAFT)
  title  String?

  // Template
  templateId   String?
  brandingMode String? // "windowworld-compatible" | "custom"

  // Customer info snapshot
  customerName    String?
  customerEmail   String?
  propertyAddress String?

  // Content
  coverNote      String?
  projectSummary String?
  termsText      String?

  // Expiration
  expiresAt DateTime?

  // Send status
  sentAt      DateTime?
  sentToEmail String?
  viewedAt    DateTime?
  viewCount   Int       @default(0)

  // E-sign
  signatureRequired Boolean   @default(false)
  signedAt          DateTime?
  signedByName      String?
  signedByIp        String?

  // PDF
  pdfUrl         String?
  pdfGeneratedAt DateTime?

  // AI content
  aiCustomerNote  String? // Customer-friendly explanation
  aiRepNotes      String? // Internal rep notes
  aiUrgencyDriver String?
  aiFinanceUpsell String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead      Lead       @relation(fields: [leadId], references: [id])
  quote     Quote?     @relation(fields: [quoteId], references: [id])
  createdBy User       @relation("createdBy", fields: [createdById], references: [id])
  template  Template?  @relation(fields: [templateId], references: [id])
  documents Document[]
  @@index([leadId])
  @@index([status])
  @@map("proposals")
}

// ============================================================
// INVOICES
// ============================================================

model Invoice {
  id             String  @id @default(uuid())
  organizationId String?
  leadId         String?
  proposalId     String?
  createdById    String

  invoiceNumber String        @unique
  grandTotal    Float         @default(0)
  depositPct    Float         @default(0)
  status        InvoiceStatus @default(DRAFT)

  // Totals
  subtotal      Float @default(0)
  taxRate       Float @default(0)
  taxAmount     Float @default(0)
  total         Float @default(0)
  depositAmount Float @default(0)
  depositPaid   Float @default(0)
  balanceDue    Float @default(0)

  // Dates
  issuedAt DateTime?
  dueAt    DateTime?
  dueDate  DateTime?
  paidAt   DateTime?

  // Install scheduling
  installDate   DateTime?
  installCrew   String?
  installStatus String?
  installNotes  String?

  // Payment
  paymentTerms  String?
  paymentMethod String?
  paymentRef    String?

  // Send status
  sentAt      DateTime?
  sentToEmail String?

  notes         String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User              @relation("createdBy", fields: [createdById], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]
  documents Document[]
  @@index([organizationId])
  @@index([leadId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLineItem {
  id        String @id @default(uuid())
  invoiceId String

  description String
  quantity    Int    @default(1)
  unitPrice   Float  @default(0)
  total       Float  @default(0)

  sortOrder Int     @default(0)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_line_items")
}

model Payment {
  id        String @id @default(uuid())
  invoiceId String

  amount    Float
  method    String? // cash, check, card, ach, financing
  reference String?
  note      String?
  isDeposit Boolean @default(false)

  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

// ============================================================
// DOCUMENTS / PHOTOS
// ============================================================

model Document {
  id           String  @id @default(uuid())
  leadId       String?
  propertyId   String?
  inspectionId String?
  openingId    String?
  proposalId   String?
  invoiceId    String?

  type         DocumentType
  filename     String
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  storageKey   String // Cloud storage key
  url          String? // Signed URL cache
  urlExpiresAt DateTime?

  // Photo context
  roomLabel          String?
  floorLevel         Int?
  captureNotes       String?
  capturedAt         DateTime?
  capturedByDeviceId String?

  // Before/after portfolio
  isBeforePhoto Boolean @default(false)
  isAfterPhoto  Boolean @default(false)
  jobId         String?

  // Processing status
  isProcessed Boolean   @default(false)
  processedAt DateTime?

  // AI
  aiAnalysisId String?

  uploadedById String?

  // Sync
  syncStatus SyncStatus @default(PENDING)
  offlineId  String? // Device-generated ID for offline capture
  syncedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead       Lead?       @relation(fields: [leadId], references: [id])
  property   Property?   @relation(fields: [propertyId], references: [id])
  inspection Inspection? @relation(fields: [inspectionId], references: [id])
  opening    Opening?    @relation(fields: [openingId], references: [id])
  uploadedBy User?       @relation("uploadedBy", fields: [uploadedById], references: [id])
  proposal   Proposal?   @relation(fields: [proposalId], references: [id])
  invoice    Invoice?    @relation(fields: [invoiceId], references: [id])
  aiAnalysis AiAnalysis? @relation(fields: [aiAnalysisId], references: [id])
  expense    JobExpense?

  @@index([leadId])
  @@index([inspectionId])
  @@index([openingId])
  @@index([propertyId])
  @@map("documents")
}

// ============================================================
// JOB EXPENSES
// ============================================================

model JobExpense {
  id             String          @id @default(cuid())
  organizationId String
  leadId         String
  createdById    String
  verifiedById   String?
  documentId     String?         @unique
  amount         Decimal         @db.Decimal(10, 2)
  category       ExpenseCategory @default(OTHER)
  vendor         String?         @db.VarChar(255)
  description    String?         @db.VarChar(1000)
  receiptDate    DateTime?
  aiParsedData   Json?
  aiConfidence   Float?
  verifiedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy  User      @relation("ExpensesCreated", fields: [createdById], references: [id])
  verifiedBy User?     @relation("ExpensesVerified", fields: [verifiedById], references: [id])
  document   Document? @relation(fields: [documentId], references: [id])

  @@index([leadId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("job_expenses")
}

// ============================================================
// AI ANALYSIS
// ============================================================

model AiAnalysis {
  id           String  @id @default(uuid())
  leadId       String?
  inspectionId String?
  openingId    String?
  documentId   String?

  analysisType String // window-classification, measurement-estimate, lead-score, pitch, summary
  provider     String // openai | anthropic | google
  model        String // gpt-4o | claude-3-5 | gemini-pro-vision

  // Input
  inputPrompt String?  @db.Text
  inputImages String[] // Document IDs used as input

  // Output
  rawResponse Json? // Full AI response

  // Window classification outputs
  detectedWindowType    WindowType?
  detectedFrameMaterial FrameMaterial?
  detectedCondition     ConditionRating?
  hasCondensation       Boolean?
  hasSealFailure        Boolean?
  replacementComplexity String?

  // Measurement estimation (clearly labeled as AI-estimated)
  estimatedWidth   Float?
  estimatedHeight  Float?
  measurementNotes String?
  refObjectUsed    Boolean?

  // Lead scoring outputs
  leadScoreOutput Json?
  pitchOutput     Json?

  // Confidence & audit
  confidenceScore     Float? // 0.0 - 1.0
  confidenceBreakdown Json?
  rationale           String?   @db.Text
  isEdited            Boolean   @default(false)
  editedById          String?
  editedAt            DateTime?
  humanOverride       Json?

  // Status
  status       JobStatus @default(PENDING)
  errorMessage String?
  retryCount   Int       @default(0)

  processingMs Int? // Processing time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead       Lead?       @relation(fields: [leadId], references: [id])
  inspection Inspection? @relation(fields: [inspectionId], references: [id])
  opening    Opening?    @relation(fields: [openingId], references: [id])
  documents  Document[]

  @@map("ai_analyses")
}

// ============================================================
// ACTIVITIES / TIMELINE
// ============================================================

model Activity {
  id     String  @id @default(uuid())
  leadId String
  userId String?

  type        ActivityType
  title       String?
  description String?      @db.Text
  outcome     String?

  // Contact attempt details
  contactMethod ContactMethod?
  duration      Int? // minutes

  // Linked records
  appointmentId String?
  proposalId    String?
  invoiceId     String?

  isAutomatic Boolean @default(false) // System-generated vs user-logged

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  lead             Lead              @relation(fields: [leadId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  communicationLog CommunicationLog?

  @@index([leadId, occurredAt])
  @@map("activities")
}

// ============================================================
// COMMUNICATION LOG (Twilio calls + SMS)
// ============================================================

model CommunicationLog {
  id             String  @id @default(uuid())
  leadId         String
  organizationId String
  userId         String? // Rep who initiated (null for inbound)

  direction String // OUTBOUND | INBOUND
  type      String // CALL | SMS

  // Twilio metadata
  twilioSid    String? @unique // CallSid or MessageSid
  to           String
  from         String
  body         String? @db.Text // SMS message body
  status       String // initiated | ringing | in-progress | completed | busy | no-answer | failed | sent | delivered
  duration     Int? // seconds (calls) or null
  recordingUrl String? // MP3 URL after call completes
  errorCode    String? // Twilio error code on failure

  // Link back to the Activity log entry
  activityId String? @unique

  simulated Boolean @default(false) // true in dev without Twilio creds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead         Lead         @relation(fields: [leadId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  activity     Activity?    @relation(fields: [activityId], references: [id])

  @@index([leadId, createdAt])
  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([type, status])
  @@map("communication_logs")
}

// ============================================================
// NOTES
// ============================================================

model Note {
  id       String  @id @default(uuid())
  leadId   String
  authorId String?

  content    String  @db.Text
  isInternal Boolean @default(false) // internal vs customer-visible
  isPinned   Boolean @default(false)

  // AI context
  isAiGenerated Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("notes")
}

// ============================================================
// TASKS
// ============================================================

model Task {
  id           String  @id @default(uuid())
  leadId       String
  assignedToId String?
  createdById  String?

  title       String
  description String?

  dueAt       DateTime?
  completedAt DateTime?
  isComplete  Boolean   @default(false)

  priority String @default("medium") // low, medium, high, urgent

  // Automation link
  automationId String?
  isAutomatic  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([assignedToId, isComplete])
  @@index([dueAt])
  @@map("tasks")
}

// ============================================================
// TEMPLATES
// ============================================================

model Template {
  id             String  @id @default(uuid())
  organizationId String?

  type     String // proposal | invoice | email | pitch | sms
  name     String
  subject  String?
  bodyHtml String? @db.Text
  bodyText String? @db.Text

  // Branding
  brandingMode String?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  variables String[] // Available template variables

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  proposals    Proposal[]

  @@map("templates")
}

// ============================================================
// CAMPAIGNS
// ============================================================

model Campaign {
  id             String @id @default(uuid())
  organizationId String

  name   String
  type   String // storm-opportunity | seasonal | referral | reengagement | custom
  status String @default("draft") // draft | active | paused | complete

  // Targeting
  targetParishes   String[]
  targetZips       String[]
  targetLeadStatus String[]
  isStormCampaign  Boolean  @default(false)
  stormEventId     String?

  // Performance
  leadCount        Int   @default(0)
  contactedCount   Int   @default(0)
  appointmentCount Int   @default(0)
  closeCount       Int   @default(0)
  revenue          Float @default(0)

  startDate DateTime?
  endDate   DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  leads        Lead[]

  @@map("campaigns")
}

// ============================================================
// AUTOMATIONS
// ============================================================

model Automation {
  id             String  @id @default(uuid())
  organizationId String?

  name        String
  description String?
  trigger     AutomationTrigger
  conditions  Json? // Rule conditions
  actions     Json // Actions to take

  isActive Boolean @default(true)

  delayMinutes Int? // Delay before executing

  runCount  Int       @default(0)
  lastRunAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs AutomationRun[]

  @@map("automations")
}

model AutomationRun {
  id           String  @id @default(uuid())
  automationId String
  leadId       String?

  status       JobStatus @default(PENDING)
  triggeredAt  DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  result Json?

  automation Automation @relation(fields: [automationId], references: [id])

  @@map("automation_runs")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id     String @id @default(uuid())
  userId String

  type  String // alert | reminder | system | task
  title String
  body  String?

  link   String? // In-app link
  isRead Boolean   @default(false)
  readAt DateTime?

  // Delivery
  channel     String // in-app | email | push | sms
  sentAt      DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// STORM EVENTS
// ============================================================

model StormEvent {
  id String @id @default(uuid())

  name     String // e.g., "Hurricane Ida Remnants", "Hail Storm - Baton Rouge NE"
  type     String // hurricane | tornado | hail | flooding | wind
  severity String // minor | moderate | major | catastrophic

  // Geography
  affectedParishes String[]
  affectedZips     String[]
  centerLat        Float?
  centerLng        Float?
  radiusMiles      Float?

  // NOAA / Weather data
  dataSource      String?
  externalEventId String?

  // Dates
  occurredAt DateTime
  dataAsOf   DateTime?

  isActive Boolean @default(true)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("storm_events")
}

// ============================================================
// SYNC EVENTS (Offline-first mobile sync)
// ============================================================

model SyncEvent {
  id       String  @id @default(uuid())
  deviceId String
  userId   String?

  entityType String // lead | measurement | document | activity | etc.
  entityId   String?
  offlineId  String? // Device-generated ID

  operation String // create | update | delete
  payload   Json

  status       SyncStatus @default(PENDING)
  conflictData Json?
  resolvedAt   DateTime?
  errorMessage String?

  retryCount Int @default(0)

  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([deviceId, status])
  @@index([status])
  @@map("sync_events")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id     String  @id @default(uuid())
  userId String?

  entityType String // lead | measurement | quote | proposal | invoice | user | etc.
  entityId   String
  action     String // create | update | delete | access | status-change | approve

  oldValues Json?
  newValues Json?

  ipAddress String?
  userAgent String?
  deviceId  String?

  occurredAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([occurredAt])
  @@map("audit_logs")
}

// ============================================================
// TAGS
// ============================================================

model Tag {
  id             String  @id @default(uuid())
  organizationId String?
  name           String
  color          String?
  entityType     String // lead | property | contact

  createdAt DateTime @default(now())

  @@unique([organizationId, name, entityType])
  @@map("tags")
}

// ============================================================
// MARKET INTELLIGENCE SYSTEM
// All data sourced from lawful public web + first-party signals only
// ============================================================

model Competitor {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  website          String?
  facebookUrl      String?
  instagramUrl     String?
  googleMapsUrl    String?
  territory        String?   // local | regional | national
  isActive         Boolean   @default(true)
  lastScrapedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  pages            CompetitorPage[]
  socialProfiles   CompetitorSocialProfile[]
  socialPosts      CompetitorSocialPost[]
  reviewInsights   ReviewInsight[]
  battlecard       Battlecard?

  @@map("competitors")
}

model CompetitorPage {
  id                String    @id @default(uuid())
  competitorId      String
  url               String
  pageType          String    // product | financing | faq | quote | about | home | reviews
  title             String?
  contentText       String?   @db.Text
  keyMessages       Json?     // String[] of extracted key claims
  ctaText           String?
  financingOffer    String?
  warrantyClaimText String?
  lastFetched       DateTime?
  createdAt         DateTime  @default(now())

  competitor        Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@map("competitor_pages")
}

model CompetitorSocialProfile {
  id              String    @id @default(uuid())
  competitorId    String
  platform        String    // facebook | instagram | youtube
  profileUrl      String
  handle          String?
  followerCount   Int?
  postFrequency   String?   // daily | weekly | monthly | sporadic
  primaryThemes   Json?     // String[] of content themes
  toneNotes       String?
  lastAnalyzed    DateTime?
  createdAt       DateTime  @default(now())

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  posts           CompetitorSocialPost[]

  @@index([competitorId, platform])
  @@map("competitor_social_profiles")
}

model CompetitorSocialPost {
  id                    String    @id @default(uuid())
  competitorId          String
  profileId             String?
  platform              String    // facebook | instagram
  postType              String    // photo | video | reel | carousel | story | text
  caption               String?   @db.Text
  hashtags              String[]
  engagementNotes       String?   // qualitative notes on visible engagement
  creativeTheme         String?   // before_after | testimonial | offer | seasonal | product | story | urgency
  productFocus          String?   // windows | doors | siding | general
  financingMention      Boolean   @default(false)
  stormMention          Boolean   @default(false)
  urgencyHook           Boolean   @default(false)
  publicCommentInsights Json?     // String[] of notable public comment themes
  postedAt              DateTime?
  createdAt             DateTime  @default(now())

  competitor    Competitor              @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  profile       CompetitorSocialProfile? @relation(fields: [profileId], references: [id])

  @@index([competitorId, platform])
  @@map("competitor_social_posts")
}

model ReviewInsight {
  id               String    @id @default(uuid())
  competitorId     String?
  source           String    // google | bbb | houzz | angi | homeadvisor | yelp | facebook
  rating           Float?
  reviewText       String?   @db.Text
  sentiment        String    // positive | negative | neutral | mixed
  topicTags        String[]  // quality | installation | price | warranty | communication | scheduling | trust
  productMentioned String?   // windows | doors | siding
  reviewerType     String?   // homeowner | property_manager | b2b
  publicUrl        String?
  reviewDate       DateTime?
  createdAt        DateTime  @default(now())

  competitor       Competitor? @relation(fields: [competitorId], references: [id])

  @@index([competitorId, sentiment])
  @@index([source])
  @@map("review_insights")
}

model ForumThreadInsight {
  id             String    @id @default(uuid())
  source         String    // reddit | houzz_community | city_data | angies_list | general_forum
  subreddit      String?
  threadTitle    String?
  threadContent  String?   @db.Text
  sentiment      String    // positive | negative | neutral | mixed
  topicTags      String[]
  productFocus   String?   // windows | doors | siding | general
  intentSignals  String[]  // financing | urgency | comparison | trust | storm | insurance
  keyQuestions   Json?     // String[] of questions found in thread
  competitorMentions String[]
  threadUrl      String?
  createdAt      DateTime  @default(now())

  @@index([source, productFocus])
  @@map("forum_thread_insights")
}

model TopicCluster {
  id             String    @id @default(uuid())
  clusterName    String
  productScope   String    // windows | doors | siding | financing | storm | social | all
  themeType      String    // buyer_concern | objection | product_interest | competitor_gap | creative_pattern | social_engagement
  frequency      Int       @default(1)
  sentimentScore Float     @default(0) // -1.0 to 1.0
  keyPhrases     String[]
  sourceSummary  Json?     // where this cluster came from
  actionableNote String?   @db.Text
  lastUpdated    DateTime  @default(now())
  createdAt      DateTime  @default(now())

  @@index([productScope, themeType])
  @@map("topic_clusters")
}

model BuyerIntentSignal {
  id               String    @id @default(uuid())
  // FIRST-PARTY ONLY — no third-party private data
  signalType       String    // page_view | form_start | form_abandon | chat_start | call_click | quote_start | financing_page | product_page | photo_upload
  sessionId        String?   // anonymous session identifier
  leadId           String?   // linked if visitor is known through lawful means
  pageUrl          String?
  productSignal    String?   // windows | doors | siding
  financingSignal  Boolean   @default(false)
  stormSignal      Boolean   @default(false)
  urgencySignal    Boolean   @default(false)
  sourceChannel    String?   // facebook | instagram | google | organic | direct | email | sms
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  metadata         Json?
  createdAt        DateTime  @default(now())

  @@index([leadId])
  @@index([sessionId])
  @@index([signalType, createdAt])
  @@map("buyer_intent_signals")
}

model AnonymousIntentProfile {
  id                  String    @id @default(uuid())
  sessionId           String    @unique
  behaviorSegment     String?   // FINANCING_FIRST | COMPARISON_SHOPPER | STORM_CLAIMANT | ENERGY_SEEKER | URGENT_REPLACER | AESTHETIC_DRIVEN | TRUST_ANXIOUS | PREMIUM_BUYER | BUDGET_CONSCIOUS
  productSignals      String[]  // windows | doors | siding
  urgencyLevel        String    @default("LOW") // LOW | MEDIUM | HIGH
  pageViewCount       Int       @default(1)
  financingPageVisit  Boolean   @default(false)
  quotePageVisit      Boolean   @default(false)
  sourceChannel       String?
  retargetingAngles   Json?     // recommended ad copy/offer angles
  lastSeen            DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([behaviorSegment])
  @@map("anonymous_intent_profiles")
}

model Battlecard {
  id               String    @id @default(uuid())
  competitorId     String    @unique
  positioning      String?   @db.Text
  keyClaims        Json?     // String[]
  pricingLanguage  String?   @db.Text
  financingOffers  String?   @db.Text
  warrantyNotes    String?   @db.Text
  ctaStrategy      String?   @db.Text
  reviewStrengths  Json?     // String[] of top praise themes
  reviewWeaknesses Json?     // String[] of top complaint themes
  messagingGaps    Json?     // String[] of where they fail buyers
  facebookNotes    String?   @db.Text
  instagramNotes   String?   @db.Text
  ourCounterPitch  String?   @db.Text
  talkTrack        String?   @db.Text
  objectionResponses Json?   // {objection: string, response: string, close: string}[]
  lastUpdated      DateTime  @default(now())
  createdAt        DateTime  @default(now())

  competitor       Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@map("battlecards")
}

model CampaignAngle {
  id              String    @id @default(uuid())
  segmentTarget   String    // FINANCING_FIRST | STORM_CLAIMANT | COMPARISON_SHOPPER | etc.
  productFocus    String    // windows | doors | siding | all
  channel         String    // facebook | instagram | google | email | sms | website
  headline        String?
  bodyText        String?   @db.Text
  ctaText         String?
  visualConcept   String?   @db.Text
  landingPagePath String?
  priority        String    @default("medium")
  createdAt       DateTime  @default(now())

  @@index([segmentTarget, channel])
  @@map("campaign_angles")
}

model SocialCreativePattern {
  id                   String    @id @default(uuid())
  platform             String    // facebook | instagram
  creativeTheme        String    // before_after | testimonial | seasonal | financing | storm | product_demo | community | urgency
  productFocus         String    // windows | doors | siding | general
  captionStyle         String?   // emotional | informational | urgency | social_proof | question | story
  visualDescription    String?   @db.Text
  performanceNotes     String?   @db.Text
  hookExample          String?
  competitorUsageCount Int       @default(0)
  recommendationLevel  String    @default("medium") // low | medium | high
  createdAt            DateTime  @default(now())

  @@index([platform, recommendationLevel])
  @@map("social_creative_patterns")
}

model ObjectionPattern {
  id                 String    @id @default(uuid())
  objectionText      String
  objectionCategory  String    // price | trust | scheduling | product_quality | financing | warranty | competition | disruption | timing
  productFocus       String?   // windows | doors | siding | general
  frequency          Int       @default(1)
  sourceTypes        String[]  // review | forum | social_comment | crm_note | chat
  responseScript     String?   @db.Text
  closeScript        String?   @db.Text
  createdAt          DateTime  @default(now())

  @@index([objectionCategory])
  @@map("objection_patterns")
}

model MessagingOpportunity {
  id                  String    @id @default(uuid())
  opportunityType     String    // unmet_concern | competitor_gap | underserved_segment | creative_gap | review_gap
  description         String    @db.Text
  productScope        String    // windows | doors | siding | financing | all
  targetSegment       String?
  recommendedMessage  String?   @db.Text
  channel             String?   // facebook | instagram | google | website | email | sms
  priority            String    @default("medium") // low | medium | high | critical
  evidenceSources     Json?
  isActedOn           Boolean   @default(false)
  createdAt           DateTime  @default(now())

  @@index([priority, isActedOn])
  @@map("messaging_opportunities")
}

