datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════════════════════════
// CORE TABLES
// ═══════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("sales_rep")
  password  String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments    Appointment[]
  auditLogs       AuditLog[]
  voiceSessions   VoiceSession[]
  pricingVersions PricingVersion[]
  timelineEvents  AppointmentTimelineEvent[]
}

model Customer {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  phone2      String?
  address     String?
  city        String?
  state       String?  @default("LA")
  zip         String?
  notes       String?
  leadSource  String?
  preLead1978 Boolean  @default(false)
  customerId  String?  // WW account/customer ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]
}

model Appointment {
  id              String    @id @default(cuid())
  customerId      String
  userId          String
  status          String    @default("draft")
  appointmentDate DateTime?
  jobAddress      String?
  jobCity         String?
  jobState        String?   @default("LA")
  jobZip          String?
  projectType     String?
  completeJob     Boolean   @default(true)
  poNumber        String?
  accountNumber   String?
  notes           String?
  estimatorNotes  String?
  installerNotes  String?
  officeNotes     String?
  subtotal        Float     @default(0)
  taxRate         Float     @default(0.0945)
  taxAmount       Float     @default(0)
  adminFee        Float     @default(0)
  discount        Float     @default(0)
  totalAmount     Float     @default(0)
  depositAmount   Float     @default(0)
  balanceDue      Float     @default(0)
  financingAmount Float     @default(0)
  pricingVersionId String?
  completionPct   Float     @default(0)
  lockedAt        DateTime?
  lockedReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer       Customer        @relation(fields: [customerId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  pricingVersion PricingVersion? @relation(fields: [pricingVersionId], references: [id])
  openings       Opening[]
  lineItems      QuoteLineItem[]
  contracts      Contract[]
  signatures     Signature[]
  payments       Payment[]
  houseMap       HouseMap?
  voiceSessions  VoiceSession[]
  formInstances  FormInstance[]
  formSketches   FormSketch[]
  timelineEvents AppointmentTimelineEvent[]
  safetyReviews      OpeningSafetyGlazingReview[]
  temperedFlags      TemperedGlazingFlag[]
  aiWarnings         AiValidationWarning[]
  measurementAdj     MeasurementAdjustment[]
  measurePhotos      MeasurementCapturePhoto[]
  specialtySessions  SpecialtyMeasurementSession[]

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([appointmentDate])
}

// ═══════════════════════════════════════════════════════════
// OPENINGS
// ═══════════════════════════════════════════════════════════

model Opening {
  id              String   @id @default(cuid())
  appointmentId   String
  openingNumber   Int
  quantity        Int      @default(1)
  roomLocation    String?
  elevation       String?
  floorNumber     Int?     @default(1)
  width           Float?
  height          Float?
  unitedInches    Float?
  productCategory String?
  productModel    String?
  seriesModel     String?
  interiorColor   String?
  exteriorColor   String?
  gridStyle       String?
  gridPattern     String?
  glassPackage    String?
  temperedGlass   String?  // none | full | half
  obscureGlass    String?  // none | full | half
  argon           Boolean  @default(false)
  foamEnhanced    Boolean  @default(false)
  lowEPackage     String?
  screenOption    String?
  nailFin         Boolean  @default(false)
  oriel           Boolean  @default(false)
  horizontalRR    Boolean  @default(false)
  hinge           String?
  exteriorType    String?
  trimType        String?
  trimNotes       String?
  removalType     String?
  installType     String?
  sillRepair      Boolean  @default(false)
  installNotes    String?
  customerNotes   String?
  installerNotes  String?
  basePrice       Float    @default(0)
  optionsPrice    Float    @default(0)
  laborPrice      Float    @default(0)
  totalPrice      Float    @default(0)
  radius          Float?
  customRadius    Float?
  legHeight       Float?
  specialtyNotes  String?
  needsVerification Boolean @default(false)
  pricingStatus   String?  @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment     Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  photos          OpeningPhoto[]
  sketchLinks     SketchMarkerLink[]

  @@index([appointmentId])
}

model OpeningPhoto {
  id        String   @id @default(cuid())
  openingId String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  opening   Opening  @relation(fields: [openingId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// PRICING ENGINE
// ═══════════════════════════════════════════════════════════

model PricingVersion {
  id          String    @id @default(cuid())
  name        String
  status      String    @default("draft") // draft | review | published | archived
  publishedAt DateTime?
  publishedBy String?
  importId    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  publisher    User?              @relation(fields: [publishedBy], references: [id])
  import       PricingImport?     @relation(fields: [importId], references: [id])
  items        PricingVersionItem[]
  appointments Appointment[]
}

model PricingVersionItem {
  id               String  @id @default(cuid())
  pricingVersionId String
  category         String  // product | option | labor | specialty | tax | removal
  productCategory  String?
  seriesModel      String?
  label            String
  unitedInchesMin  Float?
  unitedInchesMax  Float?
  price            Float   @default(0)
  priceType        String  @default("flat")
  confidence       Float   @default(1.0)
  needsVerification Boolean @default(false)
  sortOrder        Int     @default(0)
  createdAt        DateTime @default(now())

  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)

  @@index([pricingVersionId])
  @@index([category])
  @@index([productCategory])
}

model PricingImport {
  id             String   @id @default(cuid())
  fileName       String
  fileType       String   // pdf | csv | xlsx | docx
  fileSize       Int?
  source         String   @default("local") // local | google_drive
  driveFileId    String?
  status         String   @default("uploaded") // uploaded | parsing | parsed | reviewed | applied | failed
  parsedRowCount Int?
  errorMessage   String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rows     PricingImportRow[]
  versions PricingVersion[]
}

model PricingImportRow {
  id              String  @id @default(cuid())
  importId        String
  rowNumber       Int
  rawData         String? // original text
  category        String?
  productCategory String?
  seriesModel     String?
  label           String?
  unitedInchesMin Float?
  unitedInchesMax Float?
  price           Float?
  priceType       String?
  confidence      Float   @default(0.5)
  needsVerification Boolean @default(true)
  status          String  @default("pending") // pending | accepted | rejected | edited
  createdAt       DateTime @default(now())

  import PricingImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
}

model MissingPricingRule {
  id              String   @id @default(cuid())
  appointmentId   String?
  openingId       String?
  productCategory String?
  seriesModel     String?
  unitedInches    Float?
  optionLabel     String?
  description     String
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
}

// Legacy tables kept for backward compat
model PricingTable {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       PricingItem[]
}

model PricingItem {
  id                String   @id @default(cuid())
  pricingTableId    String
  label             String
  sku               String?
  unitedInchesMin   Float?
  unitedInchesMax   Float?
  seriesModel       String?
  productCategory   String?
  price             Float    @default(0)
  priceType         String   @default("flat")
  isDefault         Boolean  @default(false)
  needsVerification Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  pricingTable      PricingTable @relation(fields: [pricingTableId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// QUOTES / LINE ITEMS
// ═══════════════════════════════════════════════════════════

model QuoteLineItem {
  id            String   @id @default(cuid())
  appointmentId String
  label         String
  category      String
  quantity      Int      @default(1)
  unitPrice     Float    @default(0)
  totalPrice    Float    @default(0)
  notes         String?
  needsVerification Boolean @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// CONTRACTS / SIGNATURES / PAYMENTS
// ═══════════════════════════════════════════════════════════

model Contract {
  id            String   @id @default(cuid())
  appointmentId String
  pdfUrl        String?
  version       Int      @default(1)
  status        String   @default("draft")
  formData      String?  // JSON blob of all contract fields
  generatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Signature {
  id            String   @id @default(cuid())
  appointmentId String
  signerName    String
  signerRole    String
  signatureData String
  signedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  appointmentId String
  amount        Float
  method        String
  reference     String?
  notes         String?
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// HOUSE MAP / SKETCH
// ═══════════════════════════════════════════════════════════

model HouseMap {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  sketchData    String?  // JSON canvas data
  sketchImage   String?  // base64 or URL of sketch
  exteriorMaterial String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  markers       HouseMapMarker[]
}

model HouseMapMarker {
  id            String  @id @default(cuid())
  houseMapId    String
  elevation     String
  x             Float
  y             Float
  openingNumber Int
  label         String?
  roomName      String?
  floorLevel    Int?    @default(1)
  accessNotes   String?
  installNotes  String?
  houseMap      HouseMap @relation(fields: [houseMapId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════
// VOICE-TO-TEXT
// ═══════════════════════════════════════════════════════════

model VoiceSession {
  id            String   @id @default(cuid())
  appointmentId String?
  userId        String
  status        String   @default("recording") // recording | transcribing | parsed | reviewed | applied
  audioUrl      String?
  duration      Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
  transcripts   VoiceTranscript[]
  entities      VoiceExtractedEntity[]

  @@index([appointmentId])
  @@index([userId])
}

model VoiceTranscript {
  id             String   @id @default(cuid())
  voiceSessionId String
  rawText        String
  cleanedText    String?
  confidence     Float    @default(0)
  provider       String?  // web_speech | whisper | google
  createdAt      DateTime @default(now())

  voiceSession   VoiceSession @relation(fields: [voiceSessionId], references: [id], onDelete: Cascade)
}

model VoiceExtractedEntity {
  id             String   @id @default(cuid())
  voiceSessionId String
  entityType     String   // customer | opening | measurement | option | note
  fieldName      String   // e.g. "width", "firstName", "gridStyle"
  fieldValue     String
  openingNumber  Int?
  confidence     Float    @default(0.5)
  status         String   @default("pending") // pending | accepted | rejected | edited
  createdAt      DateTime @default(now())

  voiceSession   VoiceSession @relation(fields: [voiceSessionId], references: [id], onDelete: Cascade)

  @@index([voiceSessionId])
}

// ═══════════════════════════════════════════════════════════
// FORMS ENGINE
// ═══════════════════════════════════════════════════════════

model FormInstance {
  id            String   @id @default(cuid())
  appointmentId String
  formType      String   // order_form | contract
  status        String   @default("draft") // draft | filled | reviewed | finalized | exported
  formData      String?  // JSON blob
  pdfUrl        String?
  exportedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([formType])
}

// ═══════════════════════════════════════════════════════════
// AUDIT
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════
// NEW DRAWING ENGINE
// ═══════════════════════════════════════════════════════════

model FormSketch {
  id              String   @id @default(uuid())
  appointmentId   String
  companyId       String?
  name            String?
  completenessScore Float?
  installerClarityScore Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  layers          SketchLayer[]
  markers         SketchMarker[]
  validations     SketchMeasurementValidation[]
  pricingValidations SketchPricingValidation[]
  aiInterpretations SketchAiInterpretation[]
  warnings        SketchWarningFlag[]
  scores          SketchCompletenessScore[]
  clarityScores   InstallerClarityScore[]

  @@index([appointmentId])
  @@index([companyId])
}

model SketchLayer {
  id          String   @id @default(uuid())
  sketchId    String
  companyId   String?
  name        String
  isVisible   Boolean  @default(true)
  zIndex      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sketch      FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchMarker {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  markerType      String   // window | door | note | dimension | warning
  x               Float
  y               Float
  width           Float?
  height          Float?
  unitedInches    Float?
  elevation       String?
  roomLocation    String?
  floorNumber     Int?     @default(1)
  productType     String?
  specialtyType   String?
  installComplexity String?
  ladderReq       Boolean  @default(false)
  removalType     String?
  installType     String?
  exteriorMaterial String?
  notes           String?
  pricingStatus   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sketch          FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)
  links           SketchMarkerLink[]

  @@index([sketchId])
  @@index([companyId])
}

model SketchMarkerLink {
  id              String   @id @default(uuid())
  markerId        String
  openingId       String?
  companyId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  marker          SketchMarker @relation(fields: [markerId], references: [id], onDelete: Cascade)
  opening         Opening?     @relation(fields: [openingId], references: [id], onDelete: SetNull)

  @@index([markerId])
  @@index([openingId])
  @@index([companyId])
}

model SketchMeasurementValidation {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  openingId       String?
  markerId        String?
  status          String   // pass | fail | warning
  mismatchDetails String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sketch          FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)
  
  @@index([sketchId])
  @@index([companyId])
}

model SketchPricingValidation {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  openingId       String?
  issueType       String   // missing_labor | missing_specialty | missing_patio
  description     String?
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sketch          FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchAiInterpretation {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  interpretationType String // warning | suggestion | labor | pricing
  message         String
  confidence      Float    @default(0.0)
  applied         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sketch          FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchWarningFlag {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  warningType     String   // unlinked_marker | missing_dimensions | access_issue
  description     String
  severity        String   // low | medium | high | critical
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sketch          FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model SketchCompletenessScore {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  score           Float
  factors         String?  // JSON string
  createdAt       DateTime @default(now())

  sketch          FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

model InstallerClarityScore {
  id              String   @id @default(uuid())
  sketchId        String
  companyId       String?
  score           Float
  feedback        String?
  createdAt       DateTime @default(now())

  sketch          FormSketch @relation(fields: [sketchId], references: [id], onDelete: Cascade)

  @@index([sketchId])
  @@index([companyId])
}

// ═══════════════════════════════════════════════════════════
// BUSINESS RULES ENGINE
// ═══════════════════════════════════════════════════════════

model BusinessRule {
  id              String   @id @default(cuid())
  name            String
  description     String
  isActive        Boolean  @default(true)
  severity        String   @default("high") // blocker | high | medium | low
  triggerField    String?
  triggerValue    String?
  actionType      String   // set_field | warn | require_confirmation
  actionField     String?
  actionValue     String?
  message         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// APPOINTMENT TIMELINE
// ═══════════════════════════════════════════════════════════

model AppointmentTimelineEvent {
  id              String   @id @default(cuid())
  appointmentId   String
  eventType       String   // created | updated | status_change | signoff | pricing_run
  title           String
  description     String?
  userId          String?
  createdAt       DateTime @default(now())

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
}

// ═══════════════════════════════════════════════════════════
// SAFETY GLAZING / TEMPERED GLASS
// Louisiana-configurable safety glazing review system
// ═══════════════════════════════════════════════════════════

model OpeningSafetyGlazingReview {
  id                  String   @id @default(cuid())
  appointmentId       String
  openingId           String?
  openingNumber       Int
  safetyReviewStatus  String   @default("not_started")
  // not_started | reviewed | unsure | override | flagged
  temperedRequired    String   @default("not_reviewed")
  // yes | no | unsure | not_reviewed
  temperedFull        Boolean  @default(false)
  temperedHalf        Boolean  @default(false)
  flaggedReasons      String[] @default([])
  sourceType          String   @default("rule")
  // manual | voice | text | ai | rule | wizard_question
  sourcePhrase        String?
  confidenceScore     Int      @default(0)
  overrideReason      String?
  reviewedBy          String?
  reviewedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  metadata            Json?

  appointment         Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([openingId])
  @@index([safetyReviewStatus])
  @@index([temperedRequired])
}

model TemperedGlazingFlag {
  id              String   @id @default(cuid())
  reviewId        String?
  appointmentId   String
  openingNumber   Int
  ruleId          String
  ruleName        String
  category        String
  severity        String   @default("high")
  flagReason      String
  sourceType      String   @default("rule")
  sourcePhrase    String?
  confidence      Float    @default(0.85)
  requiresPhoto   Boolean  @default(false)
  photoHint       String?
  createdAt       DateTime @default(now())

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([ruleId])
}

model BusinessRuleExecutionLog {
  id              String   @id @default(cuid())
  ruleId          String
  ruleName        String
  appointmentId   String?
  openingId       String?
  openingNumber   Int?
  triggered       Boolean
  autoApplied     Boolean  @default(false)
  overridden      Boolean  @default(false)
  overrideReason  String?
  severity        String
  executedAt      DateTime @default(now())
  metadata        Json?

  @@index([ruleId])
  @@index([appointmentId])
}

model AiValidationWarning {
  id              String   @id @default(cuid())
  appointmentId   String
  openingId       String?
  openingNumber   Int?
  category        String
  message         String
  sourceType      String   @default("ai")
  sourcePhrase    String?
  confidence      Float    @default(0.75)
  resolved        Boolean  @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([resolved])
}

// ═══════════════════════════════════════════════════════════════
// MEASUREMENT INTELLIGENCE — Configurable takeoff/deduction engine
// ═══════════════════════════════════════════════════════════════

model MeasurementRule {
  id                     String   @id @default(cuid())
  name                   String
  description            String?
  status                 String   @default("needs_verification")
  windowType             String?
  exteriorType           String?
  installType            String?
  removalType            String?
  conditionJson          Json?
  widthTakeoffFraction   String?
  heightTakeoffFraction  String?
  widthTakeoffDecimal    Float    @default(0)
  heightTakeoffDecimal   Float    @default(0)
  minDeduction           Float?
  maxDeduction           Float?
  actionType             String   @default("deduct")
  requiresConfirmation   Boolean  @default(true)
  requiresPhoto          Boolean  @default(false)
  requiresNote           Boolean  @default(false)
  severity               String   @default("high")
  notes                  String?
  effectiveDate          DateTime?
  version                Int      @default(1)
  active                 Boolean  @default(true)
  createdBy              String?
  updatedBy              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  adjustments  MeasurementAdjustment[]
  photoReads   MeasurementPhotoRead[]
  execLogs     MeasurementRuleExecutionLog[]

  @@index([windowType])
  @@index([exteriorType])
  @@index([status])
}

model MeasurementAdjustment {
  id              String   @id @default(cuid())
  appointmentId   String
  openingId       String?
  openingNumber   Int
  sourceType      String   @default("manual")
  rawWidth        Float?
  rawHeight       Float?
  adjWidth        Float?
  adjHeight       Float?
  widthTakeoff    Float    @default(0)
  heightTakeoff   Float    @default(0)
  ruleId          String?
  ruleStatus      String?
  confidence      Float?
  approved        Boolean  @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  overrideReason  String?
  notes           String[] @default([])
  warnings        String[] @default([])
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment     Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  rule            MeasurementRule? @relation(fields: [ruleId], references: [id])

  @@index([appointmentId])
  @@index([approved])
}

model MeasurementCapturePhoto {
  id              String   @id @default(cuid())
  appointmentId   String
  openingId       String?
  openingNumber   Int?
  measurementType String
  photoUrl        String?
  storagePath     String?
  capturedBy      String?
  capturedAt      DateTime @default(now())
  metadata        Json?

  reads           MeasurementPhotoRead[]

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model MeasurementPhotoRead {
  id                String   @id @default(cuid())
  photoId           String?
  appointmentId     String
  openingNumber     Int?
  measurementType   String
  rawAiText         String?
  detectedFraction  String?
  detectedDecimal   Float?
  confidenceScore   Float?
  candidates        String[] @default([])
  selectedValue     Float?
  correctedValue    Float?
  ruleAppliedId     String?
  takeoffAmount     Float?
  finalDecimal      Float?
  finalFraction     String?
  status            String   @default("pending")
  requiresManual    Boolean  @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  photo             MeasurementCapturePhoto? @relation(fields: [photoId], references: [id])
  rule              MeasurementRule?         @relation(fields: [ruleAppliedId], references: [id])

  @@index([appointmentId])
  @@index([status])
}

model MeasurementRuleExecutionLog {
  id              String   @id @default(cuid())
  ruleId          String?
  appointmentId   String?
  openingId       String?
  openingNumber   Int?
  windowType      String?
  exteriorType    String?
  installType     String?
  rawWidth        Float?
  rawHeight       Float?
  adjWidth        Float?
  adjHeight       Float?
  widthTakeoff    Float?
  heightTakeoff   Float?
  applied         Boolean  @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  overridden      Boolean  @default(false)
  overrideReason  String?
  metadata        Json?
  createdAt       DateTime @default(now())

  rule            MeasurementRule? @relation(fields: [ruleId], references: [id])

  @@index([appointmentId])
  @@index([ruleId])
}

model SpecialtyMeasurementSession {
  id              String   @id @default(cuid())
  appointmentId   String
  openingId       String?
  openingNumber   Int
  windowType      String
  status          String   @default("in_progress")
  startedBy       String?
  completedBy     String?
  completedAt     DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  values          SpecialtyMeasurementValue[]
  validations     SpecialtyMeasurementValidation[]

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([status])
}

model SpecialtyMeasurementValue {
  id              String   @id @default(cuid())
  sessionId       String
  appointmentId   String
  openingNumber   Int?
  dimensionKey    String
  dimensionLabel  String
  rawValue        Float?
  adjustedValue   Float?
  sourceType      String   @default("manual")
  approved        Boolean  @default(false)
  approvedAt      DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())

  session         SpecialtyMeasurementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model SpecialtyMeasurementValidation {
  id              String   @id @default(cuid())
  sessionId       String
  appointmentId   String
  openingNumber   Int?
  issueType       String
  message         String
  severity        String   @default("high")
  resolved        Boolean  @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  session         SpecialtyMeasurementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ═══════════════════════════════════════════════════════════
// WORKBOOK TEMPLATE ENGINE TABLES
// ═══════════════════════════════════════════════════════════

model WorkbookTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  fileName      String
  filePath      String
  storageBucket String?
  isActive      Boolean  @default(false)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  versions      WorkbookTemplateVersion[]
  exports       WorkbookExportJob[]
}

model WorkbookTemplateVersion {
  id            String   @id @default(cuid())
  templateId    String
  versionNumber Int
  fileName      String
  filePath      String
  sheetNames    String[] // Array of sheet names detected
  isActive      Boolean  @default(false)
  changeNotes   String?
  createdBy     String?
  createdAt     DateTime @default(now())

  template      WorkbookTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldMappings WorkbookFieldMapping[]
  exports       WorkbookExportJob[]

  @@unique([templateId, versionNumber])
  @@index([templateId])
}

model WorkbookFieldMapping {
  id              String   @id @default(cuid())
  versionId       String
  sheetName       String
  cellAddress     String
  mergeRange      String?
  fieldKey        String
  fieldLabel      String
  fieldType       String   // text, number, currency, date, boolean, select, formula, signature
  sourceType      String   // customer, appointment, opening, quote, pricing, user, calculated, manual
  sourcePath      String?
  formula         String?
  required        Boolean  @default(false)
  aiPopulatable   Boolean  @default(false)
  validationRules String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  version         WorkbookTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  fieldValues     WorkbookFieldValue[]

  @@unique([versionId, sheetName, cellAddress])
  @@index([versionId])
  @@index([fieldKey])
}

model WorkbookFieldValue {
  id              String   @id @default(cuid())
  mappingId       String
  appointmentId   String
  value           String?
  normalizedValue String?
  sourceType      String?  // typed, voice, ai, rule, formula, manual
  sourceText      String?
  confidence      Float?
  reviewStatus    String   @default("pending") // pending, approved, rejected
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mapping         WorkbookFieldMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([mappingId])
}

model WorkbookExportJob {
  id              String   @id @default(cuid())
  appointmentId   String
  templateId      String
  versionId       String?
  exportFormat    String   @default("xlsx") // xlsx, pdf
  status          String   @default("pending") // pending, processing, completed, failed
  filePath        String?
  storageBucket   String?
  fileSize        Int?
  errorMessage    String?
  reconciliation  Json?    // Reconciliation results snapshot
  metadata        Json?
  createdBy       String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  template        WorkbookTemplate @relation(fields: [templateId], references: [id])
  version         WorkbookTemplateVersion? @relation(fields: [versionId], references: [id])

  @@index([appointmentId])
  @@index([templateId])
}

// ═══════════════════════════════════════════════════════════
// REFERENCE DOCUMENT TABLES
// ═══════════════════════════════════════════════════════════

model ReferenceDocument {
  id              String   @id @default(cuid())
  documentKey     String   @unique
  displayName     String
  fileName        String
  filePath        String
  documentType    String   // warranty, disclosure, finance, compliance, template
  workflowAreas   String[] // where the document is used
  customerFacing  Boolean  @default(false)
  internalOnly    Boolean  @default(false)
  requiredForPacket Boolean @default(false)
  appliesWhen     String?  // condition description
  version         String?
  effectiveDate   DateTime?
  summary         String?
  requiredAcknowledgment Boolean @default(false)
  exportPacketSection String?
  isActive        Boolean  @default(true)
  metadata        Json?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  acknowledgments DocumentAcknowledgment[]

  @@index([documentType])
}

model DocumentAcknowledgment {
  id              String   @id @default(cuid())
  documentId      String
  appointmentId   String
  acknowledgmentType String // reviewed, provided, acknowledged, in_packet
  value           Boolean  @default(false)
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  document        ReferenceDocument @relation(fields: [documentId], references: [id])

  @@unique([documentId, appointmentId, acknowledgmentType])
  @@index([appointmentId])
}

model LeadDisclosureReview {
  id                    String   @id @default(cuid())
  appointmentId         String   @unique
  customerId            String
  homeBuiltYear         Int?
  pre1978Status         String   @default("unknown") // yes, no, unknown
  disclosureRequired    Boolean  @default(false)
  disclosureProvided    Boolean  @default(false)
  reviewedWithCustomer  Boolean  @default(false)
  customerAcknowledged  Boolean  @default(false)
  reviewedBy            String?
  reviewedAt            DateTime?
  notes                 String?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([customerId])
}

model FinanceOption {
  id              String   @id @default(cuid())
  planKey         String   @unique
  name            String
  termMonths      Int
  apr             Float    @default(0)
  promoType       String   // interest_free, fixed_rate
  minimumAmount   Float?
  paymentFormula  String?
  disclosureText  String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  selections      AppointmentFinanceSelection[]
}

model AppointmentFinanceSelection {
  id              String   @id @default(cuid())
  appointmentId   String   @unique
  financeOptionId String
  jobAmount       Float?
  monthlyPayment  Float?
  amountFinanced  Float?
  discussed       Boolean  @default(false)
  inPacket        Boolean  @default(false)
  selectedBy      String?
  selectedAt      DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  financeOption   FinanceOption @relation(fields: [financeOptionId], references: [id])

  @@index([financeOptionId])
}

model CustomerDocumentPacket {
  id              String   @id @default(cuid())
  appointmentId   String
  customerId      String
  packetType      String   @default("standard") // standard, proposal, final
  status          String   @default("draft") // draft, assembled, exported
  exportFormat    String?  // pdf, xlsx
  filePath        String?
  fileSize        Int?
  documents       Json?    // Array of included document keys
  metadata        Json?
  createdBy       String?
  createdAt       DateTime @default(now())
  exportedAt      DateTime?

  @@index([appointmentId])
  @@index([customerId])
}

model DocumentExportLog {
  id              String   @id @default(cuid())
  appointmentId   String
  documentKey     String
  documentVersion String?
  exportFormat    String?
  exportedBy      String?
  exportedAt      DateTime @default(now())
  metadata        Json?

  @@index([appointmentId])
  @@index([documentKey])
}
