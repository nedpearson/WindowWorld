# WindowWorld Web (Vite) — Environment Variables
# Copy this file to apps/web/.env.local and fill in your values.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.

# API base URL — points to your Express backend
VITE_API_URL="http://localhost:3001"

# Google OAuth Client ID (same value as GOOGLE_CLIENT_ID in server/.env)
# Get from: https://console.cloud.google.com -> APIs -> Credentials -> OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=""
