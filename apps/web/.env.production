# Production environment — values baked in at Vite build time
# VITE_API_URL: relative path because frontend + API share the same Express server
VITE_API_URL=/api/v1
VITE_APP_NAME=WindowWorld
VITE_APP_ENV=production
# VITE_GOOGLE_CLIENT_ID is injected as a Railway build-time env var (set in Railway dashboard)
