# ── Supabase PostgreSQL ──
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# ── Supabase Keys ──
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
# ⚠️ SERVICE ROLE KEY — SERVER ONLY, NEVER expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Frontend Supabase (Vite public vars) ──
VITE_SUPABASE_URL=https://[PROJECT_REF].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ──
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret
APP_BASE_URL=http://localhost:5173

# ── Google Drive (for pricing import) ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key

# ── Voice / Speech-to-Text ──
SPEECH_TO_TEXT_PROVIDER=web_speech
SPEECH_TO_TEXT_API_KEY=optional-api-key

# ── PDF ──
PDF_RENDER_MODE=jspdf

# ── Storage ──
STORAGE_BUCKET_PHOTOS=wwa-opening-photos
STORAGE_BUCKET_EXPORTS=wwa-form-exports
STORAGE_BUCKET_RECORDINGS=wwa-voice-recordings
STORAGE_BUCKET_SKETCHES=wwa-sketches
