# WindowWorld — Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/windowworld_dev"

# ============================================
# REDIS (for BullMQ background jobs)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# AUTH
# ============================================
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth — required for Google Sign-In
# Get from: https://console.cloud.google.com -> APIs -> Credentials -> OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=""          # Server-side token verification (backend)
VITE_GOOGLE_CLIENT_ID=""     # Frontend GoogleOAuthProvider (must match GOOGLE_CLIENT_ID)

# ============================================
# SERVER
# ============================================
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:5173"   # Full public URL (used in email links, SMS links)

# ============================================
# AI PROVIDERS
# ============================================
OPENAI_API_KEY=""
AI_VISION_MODEL="gpt-4o"        # Model for photo/document analysis
AI_TEXT_MODEL="gpt-4o"          # Model for text generation

# ============================================
# FILE STORAGE (S3-compatible)
# ============================================
# These are the variable names the storage.service.ts actually reads:
S3_BUCKET_NAME=""               # Your S3 bucket name
S3_REGION="us-east-1"          # AWS region or 'auto' for Cloudflare R2
S3_ACCESS_KEY_ID=""             # AWS access key or R2 account key
S3_SECRET_ACCESS_KEY=""         # AWS secret key or R2 secret
S3_ENDPOINT=""                  # Optional: for S3-compatible services (Cloudflare R2, MinIO, etc.)
S3_PUBLIC_URL_PREFIX=""         # Optional: public CDN URL prefix (e.g. https://cdn.windowworldla.com)
UPLOAD_DIR="./uploads"          # Local fallback upload directory (used when S3 is not configured)

# ============================================
# EMAIL (transactional)
# ============================================
RESEND_API_KEY=""               # https://resend.com — primary email provider
EMAIL_FROM="noreply@windowworldla.com"
# Optional SMTP fallback:
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# ============================================
# PDF GENERATION
# ============================================
PUPPETEER_EXECUTABLE_PATH=""    # Optional: path to Chrome/Chromium binary
PDF_OUTPUT_DIR="./tmp/pdfs"    # Temp directory for generated PDF files

# ============================================
# SMS
# ============================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""          # e.g. +12255550100

# ============================================
# LOGGING / OBSERVABILITY
# ============================================
LOG_LEVEL="info"                # debug | info | warn | error
LOG_QUERIES="false"             # Set to "true" to log all Prisma SQL queries (dev only)
SENTRY_DSN=""                   # Optional: Sentry error tracking DSN

# ============================================
# FRONTEND (Vite — prefix VITE_ for client access)
# ============================================
VITE_API_URL="http://localhost:3001"   # Backend API base URL for the SPA
# VITE_GOOGLE_CLIENT_ID is set above in the Auth section

# ============================================
# MAPS / GEOSPATIAL (Optional)
# ============================================
GOOGLE_MAPS_API_KEY=""          # Google Maps Embed / Geocoding API

# ============================================
# PAYMENT PROCESSING (Optional)
# ============================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
