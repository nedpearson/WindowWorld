# WindowWorld — Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/windowworld_dev"

# ============================================
# REDIS (for BullMQ background jobs)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# AUTH
# ============================================
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================
# SERVER
# ============================================
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:5173"

# ============================================
# AI PROVIDERS (provider-agnostic abstraction)
# ============================================
AI_PROVIDER="openai"       # openai | anthropic | google
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
AI_VISION_MODEL="gpt-4o"
AI_TEXT_MODEL="gpt-4o"

# ============================================
# FILE STORAGE (S3-compatible abstraction)
# ============================================
STORAGE_PROVIDER="s3"      # s3 | gcs | local
AWS_S3_BUCKET=""
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_ENDPOINT=""         # Optional: for S3-compatible services (MinIO, R2, etc.)
LOCAL_UPLOAD_PATH="./uploads"  # Used when STORAGE_PROVIDER=local

# ============================================
# EMAIL (transactional email abstraction)
# ============================================
EMAIL_PROVIDER="resend"    # resend | sendgrid | smtp
RESEND_API_KEY=""
SENDGRID_API_KEY=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@windowworld.com"
EMAIL_FROM_NAME="WindowWorld"

# ============================================
# PDF GENERATION
# ============================================
PUPPETEER_EXECUTABLE_PATH=""  # Optional: path to Chrome/Chromium binary

# ============================================
# SMS (Optional)
# ============================================
SMS_PROVIDER="twilio"     # twilio | vonage
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================
# MAPS / GEOSPATIAL
# ============================================
MAPBOX_ACCESS_TOKEN=""
GOOGLE_MAPS_API_KEY=""

# ============================================
# WEATHER DATA
# ============================================
WEATHER_API_KEY=""         # OpenWeatherMap or similar
NOAA_API_KEY=""

# ============================================
# E-SIGN (Optional)
# ============================================
ESIGN_PROVIDER="docusign"  # docusign | hellosign
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_ACCOUNT_ID=""

# ============================================
# PAYMENT PROCESSING (Optional)
# ============================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================
# LOGGING / OBSERVABILITY
# ============================================
LOG_LEVEL="info"           # debug | info | warn | error
SENTRY_DSN=""

# ============================================
# APP CONFIG
# ============================================
APP_NAME="WindowWorld"
APP_URL="http://localhost:5173"
API_URL="http://localhost:3001"
DEFAULT_TIMEZONE="America/Chicago"
DEFAULT_STATE="Louisiana"
DEFAULT_CITY="Baton Rouge"
DEFAULT_CURRENCY="USD"
